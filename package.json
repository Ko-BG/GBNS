{
  "name": "padel-erbil-core-engine",
  "version": "1.0.0",
  "description": "High-performance low-latency matching, server-side physics, and e-commerce API gateway for Padel Erbil.",
  "main": "server.js",
  "type": "commonjs",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "prod": "NODE_ENV=production node server.js",
    "cluster": "NODE_ENV=production pm2 start server.js -i max --name 'padel-core-engine'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "fastify",
    "socketio",
    "matchmaking",
    "physics-engine",
    "realtime",
    "padel",
    "erbil"
  ],
  "author": "Padel Erbil Engineering Team",
  "license": "UNLICENSED",
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "fastify": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "pm2": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-organization/padel-erbil-backend.git"
  },
  "bugs": {
    "url": "https://github.com/your-organization/padel-erbil-backend/issues"
  },
  "homepage": "https://github.com/your-organization/padel-erbil-backend#readme"
}
